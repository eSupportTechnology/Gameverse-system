# ====================================
# Common ignores for Gameverse-system
# Covers: React frontend + Laravel backend
# ====================================

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
php_errors.log

# OS files
.DS_Store
Thumbs.db

# Environment files
.env
.env.*
!.env.example   # keep env.example for reference

# IDE/editor configs
/.idea
/.vscode
/.fleet
/.zed
.phpactor.json

# =========================
# React / Node (frontend)
/frontend/node_modules
/frontend/.pnp
/frontend/.pnp.js
/frontend/coverage
/frontend/build

# =========================
# Laravel (backend)
/backend/vendor
/backend/public/build
/backend/public/hot
/backend/public/storage
/backend/storage
/backend/bootstrap/cache
/backend/.nova
/backend/.phpunit.cache
/backend/.phpunit.result.cache
/backend/Homestead.json
/backend/Homestead.yaml
/backend/auth.json
